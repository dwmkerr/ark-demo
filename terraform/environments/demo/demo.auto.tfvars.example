# Copy to demo.auto.tfvars and edit. Do NOT commit real values.
region        = "eu-west-1"
admin_cidrs   = ["YOUR.IP.ADDR.0/32"]
instance_type = "t4g.medium"
use_spot      = false

# Ark operator chart — set once you have the ref, otherwise install Ark manually.
# ark_chart = "oci://ghcr.io/mckinsey/agents-at-scale-ark/ark-controller"

# Prefer TF_VAR_model_api_keys or CI/HCP variables over putting keys here.
# model_api_keys = {
#   anthropic = "sk-ant-..."
#   gemini    = "..."
# }
